{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "Lua.runtime.version": "LuaJIT",
  "Lua.runtime.builtin": {
    "basic": "enable",
    "bit": "enable",
    "bit32": "enable",
    "builtin": "enable",
    "coroutine": "enable",
    "debug": "enable",
    "ffi": "enable",
    "io": "enable",
    "jit": "enable",
    "math": "enable",
    "os": "enable",
    "package": "enable",
    "string": "enable",
    "table": "enable",
    "utf8": "enable"
  },
  "Lua.runtime.path": ["lua/?.lua", "lua/?/init.lua"],
  "Lua.workspace.library": [
    "${3rd}/luv/library",
    "${3rd}/busted/library",
    "${3rd}/luassert/library"
  ],
  "Lua.workspace.checkThirdParty": false,
  "Lua.completion.callSnippet": "Replace",
  "Lua.completion.keywordSnippet": "Replace",
  "Lua.diagnostics.neededFileStatus": {
    "*": "Any"
  },
  "Lua.diagnostics.globals": ["vim", "Snacks", "_G", "unpack"],
  "Lua.hint.enable": true,
  "Lua.hint.setType": false,
  "Lua.hint.paramType": true,
  "Lua.hint.paramName": "Disable",
  "Lua.hint.semicolon": "Disable",
  "Lua.hint.arrayIndex": "Disable"
}
